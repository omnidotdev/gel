pkgname=omnidotdev-gel-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="Declarative system management for Arch Linux (pre-built)"
arch=('x86_64')
url="https://gel.omni.dev"
license=('Apache-2.0')
depends=()
provides=('omnidotdev-gel')
conflicts=('omnidotdev-gel')
source=("$pkgname-$pkgver.tar.gz::https://github.com/omnidotdev/gel/releases/download/v$pkgver/gel-x86_64-unknown-linux-gnu.tar.gz"
        "$pkgname-$pkgver-LICENSE::https://raw.githubusercontent.com/omnidotdev/gel/v$pkgver/LICENSE.md")
sha256sums=('SKIP'
            'SKIP')

package() {
  install -Dm755 "gel" "$pkgdir/usr/bin/gel"
  install -Dm644 "$pkgname-$pkgver-LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
